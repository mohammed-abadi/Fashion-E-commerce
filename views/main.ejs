<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Fashion-E-commerce</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<header class="header">
  <div class="container header-container">
    <h1 class="logo">Fashion-E-commerce</h1>

    <nav class="nav">
      <a href="#home" class="nav-link">Home</a>
      <a href="#categories" class="nav-link">Categories</a>
      <a href="#offers" class="nav-link">Offers</a>
      <a href="#products" class="nav-link">Products</a>
      <a href="#contact" class="nav-link">Contact</a>
      <a href="/cart" class="nav-link">Cart</a>
    </nav>

    <div class="auth-buttons">
      <% if (locals.user) { %>
        <span class="username">Welcome, <%= user.username %></span>
        <a href="/auth/logout" class="btn logout-btn">Logout</a>
      <% } else { %>
        <a href="/auth/sign-in" class="btn signin-btn">Sign In</a>
        <a href="/auth/sign-up" class="btn signup-btn">Sign Up</a>
      <% } %>
    </div>
  </div>
</header>

<section id="home" class="hero">
  <div class="container hero-content">
    <h2 class="hero-title">New Collection 2026</h2>
    <p class="hero-subtitle">Upgrade your style with the latest trends</p>
    <a href="#products" class="btn hero-btn">Shop Now</a>
  </div>
</section>


<section id="categories" class="categories">
  <div class="container">
    <h2 class="section-title">Shop by Category</h2>

    <div class="category-grid">

        <a href="#jeans" class="category-card">Jeans</a>
        <a href="#shirts" class="category-card">Shirts</a>
        <a href="#tshirts" class="category-card">T-Shirts</a>
        <a href="#shorts" class="category-card">Shorts</a>
        <a href="#shoes" class="category-card">Shoes</a>
        <a href="#watches" class="category-card">Watches</a>

    </div>
  </div>
</section>


<section id="offers" class="offers">
  <div class="container">
    <h2 class="section-title">Special Offers</h2>

    <div class="offers-grid">
      <div class="offer-card">
        <h3>50% OFF T-Shirts</h3>
        <p>Limited time offer</p>
        <a href="#products" class="btn">Shop Now</a>
      </div>

      <div class="offer-card">
        <h3>Buy 1 Get 1 Free</h3>
        <p>On selected items</p>
        <a href="#products" class="btn">Shop Now</a>
      </div>

      <div class="offer-card">
        <h3>Free Shipping</h3>
        <p>On orders above $100</p>
        <a href="#products" class="btn">Shop Now</a>
      </div>
    </div>
  </div>
</section>

<section id="shirts" class="products">
  <div class="container">
    <h2 class="section-title">Shirts</h2>

    <div class="product-grid">
      <div class="product-card">
      <img src="https://dfcdn.defacto.com.tr/768/Z5182AZ_23SP_BG350_02_03.jpg" class="product-img" alt="Shirts">
        <h3 class="product-name">striped cotton shirt</h3>
        <p class="product-price">$80</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>

      <div class="product-card">
      <img src="https://img-lcwaikiki.mncdn.com/mnpadding/480/640/ffffff/pim/productimages/20252/8869601/v1/l_20252-w5o571z8-lhw-98-76-98-188_a.jpg" class="product-img" alt="Shirts">
        <h3 class="product-name">white striped shirt</h3>
        <p class="product-price">$53</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>

<div class="product-card">
      <img src="https://img-lcwaikiki.mncdn.com/mnpadding/480/640/ffffff/pim/productimages/20261/8497803/v1/l_20261-s68231z8-len-101-78-96-187_a.jpg" class="product-img" alt="Shirts">
        <h3 class="product-name">blue striped shirt</h3>
        <p class="product-price">$72</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>

<div class="product-card">
      <img src="https://dfcdn.defacto.com.tr/480/B4642AX_24SP_GN516_03_01.jpg" class="product-img" alt="Shirts">
        <h3 class="product-name">yellow striped shirt</h3>
        <p class="product-price">$90</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>

<div class="product-card">
      <img src="https://dfcdn.defacto.com.tr/768/S1240AZ_22WN_WT33_01_01.jpg" class="product-img" alt="Shirts">
        <h3 class="product-name">gray cotton shirt</h3>
        <p class="product-price">$102</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>

    </div>
  </div>
</section>

<section id="tshirts" class="products">
  <div class="container">
    <h2 class="section-title">T-Shirts</h2>

    <div class="product-grid">
      <div class="product-card">
        <img src="https://i.pinimg.com/originals/28/1f/ea/281fea5c66b6b059acdb20ee5e00461e.jpg" class="product-img" alt="T-Shirts">
        <h3 class="product-name">white oversized t-shirt</h3>
        <p class="product-price">$36</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>

<div class="product-card">
        <img src="https://st.mngbcn.com/rcs/pics/static/T4/fotos/S20/47001057_91.jpg?ts=1664876790615&imwidth=337&imdensity=2" class="product-img" alt="T-Shirts">
        <h3 class="product-name">gray T-shirt</h3>
        <p class="product-price">$31</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>

<div class="product-card">
        <img src="https://i.pinimg.com/originals/bf/80/51/bf80515a5be6282c6128312ac4691d83.jpg" class="product-img" alt="T-Shirts">
        <h3 class="product-name">black oversized t-shirt</h3>
        <p class="product-price">$36</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>

<div class="product-card">
        <img src="https://frankybros.com/wp-content/uploads/2021/12/light-pink-t-shirt-for-mens-online-in-india-franky-bros-brand.webp" class="product-img" alt="T-Shirts">
        <h3 class="product-name">pink t-shirt</h3>
        <p class="product-price">$36</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>

<div class="product-card">
        <img src="https://oldnavy.gap.com/webcontent/0053/414/966/cn53414966.jpg" class="product-img" alt="T-Shirts">
        <h3 class="product-name">blue t-shirt</h3>
        <p class="product-price">$29</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>

    </div>
  </div>
</section>

<section id="jeans" class="products">
  <div class="container">
    <h2 class="section-title">Jeans</h2>

    <div class="product-grid">
      <div class="product-card">
        <h3 class="product-name">Blue Jeans</h3>
        <p class="product-price">$100</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>
    </div>
  </div>
</section>

<section id="shorts" class="products">
  <div class="container">
    <h2 class="section-title">Shorts</h2>

    <div class="product-grid">
      <div class="product-card">
        <h3 class="product-name">Beach shorts</h3>
        <p class="product-price">$64</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>
    </div>
  </div>
</section>

<section id="shoes" class="products">
  <div class="container">
    <h2 class="section-title">Shoes</h2>

    <div class="product-grid">
      <div class="product-card">
        <h3 class="product-name">leather shoes</h3>
        <p class="product-price">$150</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>
    </div>
  </div>
</section>

<section id="watches" class="products">
  <div class="container">
    <h2 class="section-title">Watches</h2>

    <div class="product-grid">
      <div class="product-card">
        <h3 class="product-name">leather watch</h3>
        <p class="product-price">$250</p>
        <button class="btn add-to-cart">Add to Cart</button>
      </div>
    </div>
  </div>
</section>


<footer class="footer">
  <div class="container footer-container">

    <div class="footer-section">
      <h3>StyleHub</h3>
      <p>Men's fashion store for modern style</p>
    </div>

    <div class="footer-section">
      <h4>Quick Links</h4>
      <a href="#home">Home</a>
      <a href="#categories">Categories</a>
      <a href="#offers">Offers</a>
      <a href="#products">Products</a>
    </div>

    <div class="footer-section">
      <h4>Contact</h4>
      <p>Email: a66s99a4@gmail.com</p>
      <p>Phone: +973 66937709</p>
    </div>

  </div>

  <p class="footer-bottom">© 2026 The brand is managed by Abdulaziz, Mohammed, and Abdulla</p>
</footer>



<style>
.product-img {
  width: 100%;
  height: 150px;
  object-fit: cover;
  border-radius: 10px;
}

.product-card {
  width: 180px;
  border-radius: 15px;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  text-align: center;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 20px;
}
</style>
</body>
</html>


